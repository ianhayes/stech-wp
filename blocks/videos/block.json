{
	"$schema": "https://schemas.wp.org/trunk/block.json",
	"apiVersion": 3,
	"name": "stech/videos",
	"title": "Highlight Videos",
	"description": "Two-up grid of highlight video cards with thumbnail, tag and play button.",
	"category": "stech",
	"icon": "video-alt3",
	"keywords": ["videos", "highlight", "watch", "youtube", "cards"],
	"textdomain": "stech",
	"supports": {
		"align": ["full"],
		"anchor": true,
		"html": false,
		"customClassName": true,
		"multiple": true
	},
	"acf": {
		"mode": "preview",
		"renderTemplate": "render.php"
	},
	"example": {
		"attributes": {
			"mode": "preview",
			"data": {
				"videos_eyebrow": "Watch",
				"videos_heading": "Program highlights"
			}
		}
	}
}
