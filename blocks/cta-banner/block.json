{
	"$schema": "https://schemas.wp.org/trunk/block.json",
	"apiVersion": 3,
	"name": "stech/cta-banner",
	"title": "CTA Banner",
	"description": "Dark full-width call-to-action with heading, text and buttons.",
	"category": "stech",
	"icon": "megaphone",
	"keywords": ["cta", "call to action", "banner", "enroll"],
	"textdomain": "stech",
	"supports": {
		"align": ["full"],
		"anchor": true,
		"html": false,
		"customClassName": true,
		"multiple": true
	},
	"acf": {
		"mode": "preview",
		"renderTemplate": "render.php"
	},
	"example": {
		"attributes": {
			"mode": "preview",
			"data": {
				"cta_banner_heading": "Enrolling Now.",
				"cta_banner_text": "Come be part of the Southwest Tech family."
			}
		}
	}
}
